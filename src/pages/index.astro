---
// Home — the route map. Dark frame, fluorescent flicker, paper map nodes.
import BaseLayout from '../layouts/BaseLayout.astro';
import RouteMap from '../components/RouteMap.astro';
import BottomSheet from '../components/BottomSheet.astro';
import { mainPath, secretLevels } from '../lib/data';
import { withBase } from '../lib/url';
---

<BaseLayout title="Route Map" activeTab="map" dark>
  <div class="flicker" aria-hidden="true"></div>

  <div class="map-head">
    <p class="filecode">INCIDENT WALL · ROUTE THROUGH THE BACKROOMS</p>
    <h1 class="code">Route Map</h1>
    <p class="map-stats">
      <span id="map-count" data-total={mainPath.length}>0 / {mainPath.length}</span>
      LEVELS CLEARED · {secretLevels.length} SECRET FILES
    </p>
  </div>

  <RouteMap />

  <button id="map-continue" class="map-continue" type="button" hidden>CONTINUE ↓</button>

  <details class="panel panel--dim map-legend" style="position:relative;z-index:2">
    <summary class="panel-label" style="margin:0;border:0;padding:0">Map legend</summary>
    <ul class="legend-list" role="list">
      <li><span class="lg lg-ring"></span> Ring colour = survival class (green safe → red deadly)</li>
      <li><span class="lg lg-done">✓</span> Cleared level</li>
      <li><span class="lg lg-halo"></span> You are here — next objective</li>
      <li><span class="lg lg-dash"></span> Secret branch route</li>
      <li><span class="lg lg-q">?</span> Unidentified secret (reveal by opening its file, or set INTEL: FULL)</li>
      <li><span class="lg lg-hold">⊙</span> Press &amp; hold a level to mark it cleared</li>
    </ul>
  </details>

  <section class="panel panel--dim" style="position:relative;z-index:2">
    <span class="panel-label">Also on file</span>
    <div class="rail">
      <a class="chip" href={withBase('guides/')}>Field guides</a>
      <a class="chip" href={withBase('items/')}>Item registry</a>
      <a class="chip" href={withBase('entities/')}>Threat registry</a>
    </div>
  </section>

  <BottomSheet />

  <script>
    import { initMap } from '../scripts/map';
    import { load, subscribe } from '../scripts/progress';

    initMap();

    const count = document.getElementById('map-count');
    const mapData = document.getElementById('map-data');
    const mainIds: string[] = mapData
      ? (JSON.parse(mapData.textContent ?? '{}').mainIds ?? [])
      : [];
    const paintCount = () => {
      if (!count) return;
      const store = load();
      const done = mainIds.filter((id) => store.levels[id]?.done).length;
      count.textContent = `${done} / ${mainIds.length}`;
    };
    paintCount();
    subscribe(paintCount);
  </script>
</BaseLayout>
