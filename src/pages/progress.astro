---
// Expedition log: completion overview, export/import, reset.
import BaseLayout from '../layouts/BaseLayout.astro';
import ProgressRing from '../components/ProgressRing.astro';
import { mainPath, secretLevels } from '../lib/data';

const embed = {
  main: mainPath.map((l) => ({ id: l.id, name: l.name, sub: l.subtitle, part: l.part })),
  secret: secretLevels.map((l) => ({ id: l.id, name: l.name, sub: l.subtitle, part: l.part })),
};
const parts = [...new Set(mainPath.map((l) => l.part).filter((p) => p !== null))].sort() as number[];
---

<BaseLayout title="Progress" activeTab="progress">
  <div class="case-header">
    <p class="filecode">EXPEDITION LOG · PERSONNEL FILE</p>
    <h1 class="code">My Progress</h1>
  </div>

  <section class="panel">
    <span class="panel-label">Route completion</span>
    <div class="progress-hero">
      <ProgressRing size={92} id="overall-ring" />
      <div>
        <p class="progress-big" id="overall-count">— / —</p>
        <p class="progress-sub">MAIN ROUTE LEVELS CLEARED</p>
        <p class="progress-sub" id="secret-count">— SECRET FILES FOUND</p>
      </div>
    </div>
  </section>

  {
    parts.length > 1 && (
      <section class="panel">
        <span class="panel-label">By content drop</span>
        <div class="part-bars">
          {parts.map((p) => (
            <div class="part-row" data-part-row={p}>
              <span class="part-name">Part {p}</span>
              <span class="part-track">
                <span class="part-fill" data-part-fill />
              </span>
              <span class="part-count" data-part-count>
                —
              </span>
            </div>
          ))}
        </div>
      </section>
    )
  }

  <section class="panel">
    <span class="panel-label">Cleared level files</span>
    <ul class="cleared-list" id="cleared-list" role="list">
      <li class="cleared-empty">NOTHING CLEARED YET. THE LOBBY AWAITS.</li>
    </ul>
  </section>

  <section class="panel">
    <span class="panel-label">Expedition statistics</span>
    <dl class="kv" id="stats-kv">
      <div><dt>Cleared</dt><span class="dots"></span><dd data-stat="cleared">—</dd></div>
      <div><dt>Secrets found</dt><span class="dots"></span><dd data-stat="secrets">—</dd></div>
      <div><dt>Total deaths</dt><span class="dots"></span><dd data-stat="deaths">—</dd></div>
      <div><dt>First clear</dt><span class="dots"></span><dd data-stat="first">—</dd></div>
      <div><dt>Latest clear</dt><span class="dots"></span><dd data-stat="latest">—</dd></div>
    </dl>
    <button id="btn-report" class="btn" type="button" style="width:100%;margin-top:14px">
      Generate expedition report card
    </button>
    <div id="report-out" class="report-out" hidden>
      <img id="report-img" alt="Expedition report card" />
      <div class="transfer-actions">
        <button id="btn-report-share" class="btn btn--ghost" type="button" hidden>Share card</button>
        <a id="btn-report-save" class="btn btn--ghost" download="backrooms-expedition-report.png">Save image</a>
      </div>
    </div>
  </section>

  <section class="panel">
    <span class="panel-label">Transfer record — move progress between devices</span>
    <p class="progress-note">
      Progress lives only in this browser. Copy the record below to move it, or paste a
      record from another device and apply it.
    </p>
    <textarea
      id="transfer-box"
      class="transfer-box"
      rows="4"
      autocomplete="off"
      autocapitalize="off"
      spellcheck="false"
      aria-label="Progress record JSON"></textarea>
    <div class="transfer-actions">
      <button id="btn-export" class="btn btn--ghost" type="button">Export</button>
      <button id="btn-copy" class="btn btn--ghost" type="button">Copy</button>
      <button id="btn-link" class="btn btn--ghost" type="button">Copy link</button>
      <button id="btn-share" class="btn btn--ghost" type="button" hidden>Share</button>
      <button id="btn-import" class="btn" type="button">Apply record</button>
    </div>
    <p class="transfer-status" id="transfer-status" role="status"></p>
    <button id="btn-reset" class="btn btn--hazard" type="button" style="width:100%;margin-top:14px">
      Burn the record — reset all progress
    </button>
  </section>

  <script type="application/json" id="progress-data" set:html={JSON.stringify(embed)} />

  <script>
    import { load, replaceStore, subscribe, totalDeaths, type Store } from '../scripts/progress';
    import { drawReport } from '../scripts/report';
    import { showToast } from '../scripts/toast';

    type Row = { id: string; name: string; sub: string | null; part: number | null };
    const data = JSON.parse(
      document.getElementById('progress-data')?.textContent ?? '{"main":[],"secret":[]}',
    ) as { main: Row[]; secret: Row[] };

    const ring = document.getElementById('overall-ring');
    const overall = document.getElementById('overall-count');
    const secretEl = document.getElementById('secret-count');
    const list = document.getElementById('cleared-list');

    const fmt = (iso?: string) => {
      if (!iso) return '';
      const d = new Date(iso);
      return isNaN(d.getTime())
        ? ''
        : d.toLocaleDateString(undefined, { month: 'short', day: 'numeric' });
    };

    function paint() {
      const store = load();
      const doneMain = data.main.filter((l) => store.levels[l.id]?.done);
      const doneSecret = data.secret.filter((l) => store.levels[l.id]?.done);
      if (overall) overall.textContent = `${doneMain.length} / ${data.main.length}`;
      if (secretEl)
        secretEl.textContent = `${doneSecret.length} / ${data.secret.length} SECRET FILES FOUND`;
      ring?.style.setProperty(
        '--frac',
        data.main.length ? String(doneMain.length / data.main.length) : '0',
      );
      for (const row of document.querySelectorAll<HTMLElement>('[data-part-row]')) {
        const p = Number(row.dataset.partRow);
        const all = data.main.filter((l) => l.part === p);
        const done = all.filter((l) => store.levels[l.id]?.done).length;
        row
          .querySelector<HTMLElement>('[data-part-fill]')
          ?.style.setProperty('width', all.length ? `${(done / all.length) * 100}%` : '0%');
        const count = row.querySelector('[data-part-count]');
        if (count) count.textContent = `${done}/${all.length}`;
      }
      if (list) {
        const all = [...doneMain, ...doneSecret];
        list.innerHTML = all.length
          ? all
              .map((l) => {
                const at = fmt(store.levels[l.id]?.completedAt);
                return `<li><span class="cleared-name">${l.name}${l.sub ? ` — ${l.sub}` : ''}</span><span class="dots"></span><span class="cleared-date">${at || 'CLEARED'}</span></li>`;
              })
              .join('')
          : '<li class="cleared-empty">NOTHING CLEARED YET. THE LOBBY AWAITS.</li>';
      }
    }

    // expedition statistics
    const statsPaint = () => {
      const store = load();
      const doneMain = data.main.filter((l) => store.levels[l.id]?.done);
      const doneSecret = data.secret.filter((l) => store.levels[l.id]?.done);
      const dates = [...doneMain, ...doneSecret]
        .map((l) => store.levels[l.id]?.completedAt)
        .filter((d): d is string => Boolean(d))
        .sort();
      const set = (k: string, v: string) => {
        const el = document.querySelector(`[data-stat="${k}"]`);
        if (el) el.textContent = v;
      };
      set('cleared', `${doneMain.length} / ${data.main.length}`);
      set('secrets', `${doneSecret.length} / ${data.secret.length}`);
      set('deaths', String(totalDeaths()));
      set('first', dates[0] ? fmt(dates[0]) || '—' : '—');
      set('latest', dates.length ? fmt(dates[dates.length - 1]) || '—' : '—');
    };

    paint();
    statsPaint();
    subscribe(paint);
    subscribe(statsPaint);

    // expedition report card
    const siteUrl = window.location.host + import.meta.env.BASE_URL.replace(/\/$/, '');
    document.getElementById('btn-report')?.addEventListener('click', async () => {
      const canvas = await drawReport({ main: data.main, secret: data.secret, siteUrl });
      const out = document.getElementById('report-out')!;
      const img = document.getElementById('report-img') as HTMLImageElement;
      const url = canvas.toDataURL('image/png');
      img.src = url;
      (document.getElementById('btn-report-save') as HTMLAnchorElement).href = url;
      out.hidden = false;
      canvas.toBlob((blob) => {
        if (!blob) return;
        const file = new File([blob], 'backrooms-expedition-report.png', { type: 'image/png' });
        const shareBtn = document.getElementById('btn-report-share')!;
        if (navigator.canShare?.({ files: [file] })) {
          shareBtn.hidden = false;
          shareBtn.addEventListener('click', () => {
            void navigator.share({ files: [file], title: 'Backrooms expedition report' }).catch(() => {});
          });
        }
      });
      out.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
    });

    // progress-by-link: #log=<base64> imports on load; COPY LINK exports
    const encodeStore = () =>
      btoa(unescape(encodeURIComponent(JSON.stringify(load())))).replace(/=+$/, '');
    document.getElementById('btn-link')?.addEventListener('click', async () => {
      const url = `${window.location.origin}${window.location.pathname}#log=${encodeStore()}`;
      try {
        await navigator.clipboard.writeText(url);
        showToast('LINK COPIED — SEND IT TO A FELLOW WANDERER');
      } catch {
        box.value = url;
        showToast('LINK PLACED IN THE BOX BELOW');
      }
    });
    if (window.location.hash.startsWith('#log=')) {
      try {
        const json = decodeURIComponent(escape(atob(window.location.hash.slice(5))));
        const parsed = JSON.parse(json) as Store;
        if (
          parsed.version === 1 &&
          parsed.levels &&
          window.confirm('Apply the progress record from this link? It overwrites this device.')
        ) {
          replaceStore({ ...parsed, spoilers: parsed.spoilers === 'full' ? 'full' : 'light' });
          showToast('RECORD APPLIED FROM LINK.');
        }
      } catch {
        showToast('LINK RECORD UNREADABLE.');
      }
      history.replaceState(null, '', window.location.pathname);
    }

    // transfer record
    const box = document.getElementById('transfer-box') as HTMLTextAreaElement;
    const status = document.getElementById('transfer-status')!;
    const say = (msg: string) => {
      status.textContent = msg;
      window.setTimeout(() => {
        if (status.textContent === msg) status.textContent = '';
      }, 4000);
    };

    document.getElementById('btn-export')?.addEventListener('click', () => {
      box.value = JSON.stringify(load());
      say('RECORD EXPORTED BELOW.');
    });

    document.getElementById('btn-copy')?.addEventListener('click', async () => {
      if (!box.value) box.value = JSON.stringify(load());
      try {
        await navigator.clipboard.writeText(box.value);
        say('COPIED TO CLIPBOARD.');
      } catch {
        box.select();
        say('SELECT + COPY MANUALLY.');
      }
    });

    const shareBtn = document.getElementById('btn-share');
    if (shareBtn && 'share' in navigator) {
      shareBtn.hidden = false;
      shareBtn.addEventListener('click', () => {
        void navigator.share({
          title: 'Backrooms Field Manual — progress record',
          text: box.value || JSON.stringify(load()),
        }).catch(() => {});
      });
    }

    document.getElementById('btn-import')?.addEventListener('click', () => {
      try {
        const parsed = JSON.parse(box.value) as Store;
        if (parsed.version !== 1 || typeof parsed.levels !== 'object' || !parsed.levels) {
          say('NOT A VALID RECORD.');
          return;
        }
        if (!window.confirm('Overwrite this device’s progress with the pasted record?')) return;
        replaceStore({
          version: 1,
          spoilers: parsed.spoilers === 'full' ? 'full' : 'light',
          levels: parsed.levels,
        });
        say('RECORD APPLIED.');
      } catch {
        say('NOT A VALID RECORD.');
      }
    });

    document.getElementById('btn-reset')?.addEventListener('click', () => {
      if (!window.confirm('Reset ALL progress on this device?')) return;
      replaceStore({ version: 1, spoilers: load().spoilers, levels: {} });
      say('RECORD BURNED.');
    });
  </script>
</BaseLayout>
