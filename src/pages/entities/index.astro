---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EntityCard from '../../components/EntityCard.astro';
import { entities } from '../../lib/data';

// most dangerous first, then alphabetical
const rank: Record<string, number> = {
  'very deadly': 0,
  deadly: 1,
  dangerous: 2,
  high: 2,
  moderate: 3,
  low: 4,
  harmless: 5,
  friendly: 5,
  'cannot harm you': 5,
};
const sorted = [...entities].sort((a, b) => {
  const ra = rank[a.dangerLabel.toLowerCase()] ?? 3.5;
  const rb = rank[b.dangerLabel.toLowerCase()] ?? 3.5;
  return ra - rb || a.name.localeCompare(b.name);
});
---

<BaseLayout title="Entities" activeTab="entities">
  <h1 class="visually-hidden">Entities</h1>
  <div class="case-header">
    <p class="filecode">THREAT REGISTRY · {entities.length} KNOWN ENTITIES</p>
    <h2 style="border:0;margin:0" class="code">Entities</h2>
  </div>

  <div class="rail filter-rail" role="group" aria-label="Filter by danger">
    <button class="chip on" type="button" data-filter-danger="*" aria-pressed="true">All</button>
    <button class="chip" type="button" data-filter-danger="deadly" aria-pressed="false">Deadly</button>
    <button class="chip" type="button" data-filter-danger="dangerous" aria-pressed="false">Dangerous</button>
    <button class="chip" type="button" data-filter-danger="moderate" aria-pressed="false">Moderate</button>
    <button class="chip" type="button" data-filter-danger="harmless" aria-pressed="false">Harmless</button>
  </div>

  <div class="card-grid">
    {sorted.map((e) => <EntityCard entity={e} />)}
  </div>
  <p class="filter-empty" id="entity-filter-empty" hidden>NO ENTITIES MATCH THE FILTER.</p>

  <script>
    const BUCKETS: Record<string, string[]> = {
      deadly: ['deadly', 'very deadly', 'extreme'],
      dangerous: ['dangerous', 'high'],
      moderate: ['moderate', 'medium'],
      harmless: ['harmless', 'friendly', 'cannot harm you', 'minimal', 'low', 'none'],
    };
    const chips = [...document.querySelectorAll<HTMLButtonElement>('[data-filter-danger]')];
    const cards = [...document.querySelectorAll<HTMLElement>('[data-entity-card]')];
    const empty = document.getElementById('entity-filter-empty')!;

    for (const chip of chips) {
      chip.addEventListener('click', () => {
        const key = chip.dataset.filterDanger ?? '*';
        for (const c of chips) {
          const on = c === chip;
          c.classList.toggle('on', on);
          c.setAttribute('aria-pressed', String(on));
        }
        let shown = 0;
        for (const card of cards) {
          const on = key === '*' || (BUCKETS[key] ?? []).includes(card.dataset.danger ?? '');
          card.style.display = on ? '' : 'none';
          if (on) shown++;
        }
        empty.hidden = shown > 0;
      });
    }
  </script>
</BaseLayout>
