---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CaseFileHeader from '../../components/CaseFileHeader.astro';
import { dangerColorVar, entities, heroOf, levelById } from '../../lib/data';
import { imageUrl, resolveHtml, withBase } from '../../lib/url';
import type { Entity } from '../../types';

export function getStaticPaths() {
  return entities.map((e) => ({ params: { id: e.id }, props: { entity: e } }));
}

const { entity } = Astro.props as { entity: Entity };
const hero = heroOf(entity);
const seenIn = entity.levels.map((id) => levelById.get(id)).filter(Boolean);
---

<BaseLayout
  title={entity.name}
  description={entity.summary}
  activeTab="entities"
  sourceUrl={entity.sourceUrl}
>
  <CaseFileHeader
    code={entity.name}
    fileTag={`THREAT FILE · ${entity.id.toUpperCase()}`}
    crumb={{ href: withBase('entities/'), label: 'Entities' }}
  >
    <span class="badge badge--fill" style={`--badge-c:${dangerColorVar(entity.dangerLabel)}`}>
      <span class="dot" aria-hidden="true"></span>
      {entity.dangerLabel}
    </span>
    {entity.species && <span class="badge" style="--badge-c:var(--ink-soft)">{entity.species}</span>}
  </CaseFileHeader>

  {
    hero && (
      <img
        class="hero"
        src={imageUrl(hero.file)}
        alt={`Photograph of ${entity.name}`}
        width={hero.width}
        height={hero.height}
        decoding="async"
      />
    )
  }

  {entity.summary && <p class="lede">{entity.summary}</p>}

  {
    seenIn.length > 0 && (
      <section class="panel">
        <span class="panel-label">Sighted in</span>
        <div class="rail">
          {seenIn.map((l) => (
            <a class="chip" href={withBase(`levels/${l!.id}/`)}>
              {l!.name}
            </a>
          ))}
        </div>
      </section>
    )
  }

  {
    entity.sections.map((s) => (
      <section>
        <h2>{s.title}</h2>
        <div set:html={resolveHtml(s.html)} />
      </section>
    ))
  }
</BaseLayout>
